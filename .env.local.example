# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database
# Local dev / migrations: use the direct connection (port 5432).
# Vercel / serverless: use the Supabase Pooler URL (port 6543, transaction mode).
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Anthropic (Claude API — used for transcript summaries + account enrichment)
ANTHROPIC_API_KEY=sk-ant-...

# Trigger.dev (background jobs)
TRIGGER_PROJECT_ID=proj_...
TRIGGER_SECRET_KEY=tr_dev_...

# Meta Ads OAuth
META_APP_ID=
META_APP_SECRET=
META_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/meta/callback

# CRM (Pipedrive) OAuth
# CRM_STATE_SECRET must be at least 32 chars (used to sign OAuth state)
CRM_STATE_SECRET=replace-with-32-plus-character-secret-string
PIPEDRIVE_CLIENT_ID=
PIPEDRIVE_CLIENT_SECRET=
PIPEDRIVE_REDIRECT_URI=http://localhost:3000/api/auth/crm/pipedrive/callback

# Google Drive OAuth (optional — Drive auto-import is disabled if any of these is empty)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
