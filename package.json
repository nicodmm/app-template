{
  "name": "app-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate",
    "db:generate:custom": "dotenv -e .env.local -- drizzle-kit generate --custom",
    "db:migrate": "dotenv -e .env.local -- tsx scripts/migrate.ts",
    "db:rollback": "dotenv -e .env.local -- tsx scripts/rollback.ts",
    "db:status": "dotenv -e .env.local -- drizzle-kit migrate --dry-run",
    "db:generate:prod": "dotenv -e .env.prod -- drizzle-kit generate",
    "db:migrate:prod": "dotenv -e .env.prod -- tsx scripts/migrate.ts",
    "db:rollback:prod": "dotenv -e .env.prod -- tsx scripts/rollback.ts",
    "db:status:prod": "dotenv -e .env.prod -- drizzle-kit migrate --dry-run",
    "db:seed:crm": "dotenv -e .env.local -- tsx scripts/seed-crm.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.45.0",
    "@t3-oss/env-nextjs": "^0.11.0",
    "@trigger.dev/react-hooks": "4.4.4",
    "@trigger.dev/sdk": "4.4.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "drizzle-orm": "^0.38.0",
    "jose": "^6.2.2",
    "lucide-react": "^0.460.0",
    "mammoth": "^1.12.0",
    "next": "^15.0.0",
    "pdfjs-dist": "^5.6.205",
    "postgres": "^3.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^2.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv-cli": "^8.0.0",
    "drizzle-kit": "^0.30.0",
    "prettier": "^3.3.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0"
  }
}
